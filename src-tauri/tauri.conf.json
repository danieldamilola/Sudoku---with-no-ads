{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sudoku",
  "version": "1.0.0",
  "identifier": "com.danieldamilola.sudoku",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "echo ready",
    "beforeBuildCommand": "npx expo export --platform web"
  },
  "app": {
    "windows": [
      {
        "title": "Sudoku",
        "width": 420,
        "height": 860,
        "minWidth": 380,
        "minHeight": 700,
        "maxWidth": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#f5f0e8"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Daniel Damilola",
    "copyright": "© 2025 Daniel Damilola",
    "shortDescription": "Sudoku — No ads. No noise. Just the puzzle.",
    "longDescription": "A clean, minimal Sudoku app with no ads, hints, notes, and multiple difficulty levels.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
